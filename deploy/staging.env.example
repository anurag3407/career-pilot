# Staging Environment Configuration
# Copy this file to staging.env and replace placeholder values before deployment.
# Do not commit real secrets.

NODE_ENV=staging
PORT=5000

# Application URLs
FRONTEND_URL=https://staging.example.com
VITE_API_URL=https://staging-api.example.com

# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_PATH=./path/to/staging-service-account-key.json
FIREBASE_PROJECT_ID=your-staging-project-id
FIREBASE_STORAGE_BUCKET=your-staging-project-id.appspot.com

VITE_FIREBASE_API_KEY=your_staging_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-staging-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_staging_project_id
VITE_FIREBASE_STORAGE_BUCKET=your-staging-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_staging_sender_id
VITE_FIREBASE_APP_ID=your_staging_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_staging_measurement_id

# Database
MONGODB_URI=mongodb://localhost:27017/velocity_staging

# AI/API Keys
GEMINI_API_KEY=your_staging_gemini_api_key
GROQ_API_KEY=your_staging_groq_api_key
RAPIDAPI_KEY=your_staging_rapidapi_key
RAPID_HOST=your_staging_rapidapi_host

# Email Configuration
EMAIL_USER=your_staging_email@gmail.com
EMAIL_PASS=your_staging_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SERVICE_URL=https://your-staging-email-service.vercel.app
EMAIL_API_KEY=your_staging_email_api_key

# Redis
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Alerts
ALERT_CRON_SCHEDULE=0 */6 * * *
ALERT_TEST_INTERVAL=

# Razorpay
RAZORPAY_KEY_ID=your_staging_razorpay_key_id
RAZORPAY_KEY_SECRET=your_staging_razorpay_key_secret

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_staging_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_staging_linkedin_client_secret
LINKEDIN_REDIRECT_URI=https://staging-api.example.com/api/auth/linkedin/callback

# Frontend Upload Configuration
VITE_MAX_SIZE_MB=5
