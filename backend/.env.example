# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/

# Firebase Admin
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# AI
GEMINI_API_KEY=your-gemini-api-key

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=optional-password

# RapidAPI (Job Search)
RAPID_API_KEY=your-rapidapi-key
RAPID_API_HOST=jsearch.p.rapidapi.com

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# RapidAPI host for the job search endpoint
# Type: string
RAPIDAPI_HOST=jsearch.p.rapidapi.com


# -----------------------------------------------------------------------------
# EMAIL - NODEMAILER
# -----------------------------------------------------------------------------

# Sender address for job alert emails
# Type: string (email)
EMAIL_USER=no-reply@example.com

# SMTP password or app-specific password
# Type: string
EMAIL_PASS=your_gmail_app_password_here

# SMTP server hostname
# Type: string
EMAIL_HOST=smtp.gmail.com

# SMTP port (587 for TLS, 465 for SSL)
# Type: number
EMAIL_PORT=587

# External email microservice URL (used in staging/production)
# Type: string (URL)
EMAIL_SERVICE_URL=https://email-service.example.com

# API key to authenticate requests to the email microservice
# Type: string
EMAIL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# REDIS - JOB QUEUE (BULLMQ) & API CACHING LAYER
# -----------------------------------------------------------------------------

# Redis connection URL - used by BullMQ and API Caching Layer
# Type: string (URI)
# Upstash format: rediss://:password@host:port
REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

# Time window for rate limiting in milliseconds (default: 15 minutes)
# Type: number
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Razorpay (Payment Gateway)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/auth/linkedin/callback

# Two-Factor Authentication
TOTP_ENCRYPTION_KEY=your-32-char-encryption-key

# Job Alert Schedule (optional override)
ALERT_CRON_SCHEDULE=0 0 */2 * *

# AI Provider (optional: gemini | groq | openai)
AI_PROVIDER=gemini
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key

# Comma-separated Firebase UIDs allowed to call admin-only endpoints (e.g. POST /api/community/fix-likes)
# Example: ADMIN_UIDS=uid1abc,uid2def
ADMIN_UIDS=
