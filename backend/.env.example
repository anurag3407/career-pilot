# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/

# Firebase Admin
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# AI
GEMINI_API_KEY=your-gemini-api-key

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=optional-password

# RapidAPI (Job Search)
RAPID_API_KEY=your-rapidapi-key
RAPID_API_HOST=jsearch.p.rapidapi.com

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Razorpay (Payment Gateway)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/auth/linkedin/callback



# Job Alert Schedule (optional override)
ALERT_CRON_SCHEDULE=0 0 */2 * *

# AI Provider (optional: gemini | groq | openai)
AI_PROVIDER=gemini
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key

# Two-Factor Authentication
# 64-character hex key used to encrypt TOTP secrets
# Type: string (64-char hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# =========================================================
# PORTFOLIO DEPLOYMENT - GITHUB PAGES
# =========================================================

# GitHub OAuth App Client ID — used to initiate the OAuth flow so users can
# grant Career Pilot permission to create and manage their portfolio repos.
# Type: string
# Register at: https://github.com/settings/applications/new
#   - Authorization callback URL: http://localhost:5000/api/auth/github/callback
GITHUB_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# GitHub OAuth App Client Secret
# Type: string
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# =========================================================
# PORTFOLIO DEPLOYMENT - CLOUDFLARE PAGES
# =========================================================

# Cloudflare API token with "Cloudflare Pages: Edit" permission
# Type: string
# Create at: https://dash.cloudflare.com/profile/api-tokens
#   → Create Token → Edit Cloudflare Pages (template)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Cloudflare Account ID — found in the right sidebar of any zone/dashboard page
# Type: string
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret used to verify HMAC-SHA256 signatures on deployment webhook events.
# Set this to a strong random string and configure the same value in your
# Cloudflare Notifications webhook URL settings.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Type: string
CLOUDFLARE_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# =========================================================
# PORTFOLIO DEPLOYMENT - NETLIFY
# =========================================================

# Personal access token for the Netlify API
# Type: string
# Generate at: https://app.netlify.com/user/applications#personal-access-tokens
# Note: Each user can supply their own token per request; this value is the
#       server-owned fallback used when no per-request token is provided.
NETLIFY_ACCESS_TOKEN=your_netlify_personal_access_token_here


# =========================================================
# PORTFOLIO DEPLOYMENT - VERCEL
# =========================================================

# Personal access token for Vercel API
# Type: string
VERCEL_TOKEN=your_vercel_token


# =========================================================
# SECURITY
# =========================================================

# General-purpose encryption key for securing sensitive tokens (API tokens, session tokens, password-reset tokens, JWTs, etc.)
# Type: string (64-char hex recommended)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_secure_encryption_key


# =========================================================
# FEATURE FLAGS
# =========================================================

# Enable premium themes feature
# Type: boolean
ENABLE_PREMIUM_THEMES=false


# =========================================================
# LOCAL DEVELOPMENT ONLY - never set these to true in production
# =========================================================

# Bypass Firebase auth verification for local testing
# Type: boolean
DEV_BYPASS_AUTH=false

# UID to use when auth bypass is enabled
# Type: string
DEV_USER_UID=dev-user-001

# Email to use when auth bypass is enabled
# Type: string (email)
DEV_USER_EMAIL=dev@example.com

