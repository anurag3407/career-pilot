# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/

# Firebase Admin
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# AI
GEMINI_API_KEY=your-gemini-api-key

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=optional-password

# RapidAPI (Job Search)
RAPID_API_KEY=your-rapidapi-key
RAPID_API_HOST=jsearch.p.rapidapi.com

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Razorpay (Payment Gateway)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/auth/linkedin/callback

# Two-Factor Authentication
TOTP_ENCRYPTION_KEY=your-32-char-encryption-key

# Job Alert Schedule (optional override)
ALERT_CRON_SCHEDULE=0 0 */2 * *

# Scraper CAPTCHA handling (optional)
# Comma-separated proxies used for CAPTCHA retry rotation, e.g. http://user:pass@host:8080
SCRAPER_PROXIES=
CAPTCHA_CIRCUIT_WINDOW_MS=600000
CAPTCHA_CIRCUIT_MAX_RATE=0.4
CAPTCHA_CIRCUIT_MIN_SAMPLES=5
CAPTCHA_CIRCUIT_COOLDOWN_MS=300000
# Optional solver provider: 2captcha | anti-captcha
CAPTCHA_SOLVER_PROVIDER=
TWO_CAPTCHA_API_KEY=
ANTI_CAPTCHA_API_KEY=
CAPTCHA_SOLVER_POLL_MS=5000
CAPTCHA_SOLVER_TIMEOUT_MS=120000

# AI Provider (optional: gemini | groq | openai)
AI_PROVIDER=gemini
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key

# Comma-separated Firebase UIDs allowed to call admin-only endpoints (e.g. POST /api/community/fix-likes)
# Example: ADMIN_UIDS=uid1abc,uid2def
ADMIN_UIDS=
