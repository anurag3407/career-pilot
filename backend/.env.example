# Server
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/careerpilot

# JWT
JWT_SECRET=your_jwt_secret_here
TOTP_ENCRYPTION_KEY=your_totp_encryption_key_here

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVICE_ACCOUNT=your_firebase_service_account_json
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# AI APIs
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GROQ_API_KEY=your_groq_api_key

# Cloudinary
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_WEBHOOK_SECRET=your_cloudflare_webhook_secret

# Email
EMAIL_SERVICE_URL=your_email_service_url
EMAIL_API_KEY=your_email_api_key
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password
EMAIL_TLS_CA=your_tls_ca
MAIL_ALLOW_INSECURE=false

# Redis
REDIS_URL=redis://localhost:6379

# GitHub
GITHUB_TOKEN=your_github_token
ENABLE_GITHUB_SYNC_CRON=false

# RapidAPI
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=your_rapidapi_host

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Netlify
NETLIFY_ACCESS_TOKEN=your_netlify_access_token

# Proxycurl
PROXYCURL_API_KEY=your_proxycurl_api_key

# Chromium
CHROMIUM_PATH=/usr/bin/chromium-browser

# Admin
ADMIN_EMAILS=admin@example.com
ADMIN_UIDS=your_admin_uid

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Portfolio
PORTFOLIO_BASE_URL=http://localhost:5173/portfolio

# Weekly Digest
WEEKLY_DIGEST_TIMEZONE=UTC
WEEKLY_DIGEST_CONCURRENCY=5

# Alerts
ALERT_CRON_SCHEDULE=0 9 * * *
ALERT_TEST_INTERVAL=60000

# Dev Only
DEV_BYPASS_AUTH=false
DEV_USER_EMAIL=dev@example.com
ALLOW_DEV_DB_MUTATIONS=false
ALLOW_DEV_SOCKET_AUTH=false
ENABLE_DB_PROFILING=false
